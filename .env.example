# Required API keys
INTENT_GROQ_API_KEY=gsk_...
RAG_GROQ_API_KEY=gsk_...

# Qdrant vector database
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your_qdrant_key
QDRANT_COLLECTION=Mental-Health

# Optional: use same key as fallback
# GROQ_API_KEY=gsk_...

# Optional: LangSmith observability
# LANGSMITH_API_KEY=ls__...
# LANGSMITH_PROJECT=Mento

# Optional: Google Sheets feedback
# FEEDBACK_APPS_SCRIPT_URL=https://script.google.com/macros/s/.../exec
# FEEDBACK_APPS_SCRIPT_SECRET=
# FEEDBACK_APPS_SCRIPT_TIMEOUT=10

# Optional: rebuild Qdrant index on startup
# BUILD_INDEX_ON_STARTUP=true
# FORCE_REBUILD_INDEX=false

# Optional: Flask config
# FLASK_RUN_HOST=0.0.0.0
# FLASK_RUN_PORT=5000
# FLASK_DEBUG=false

# Optional: emotion model memory guard (Windows)
# USE_LOCAL_EMOTION_MODEL=true
# MIN_AVAILABLE_PAGEFILE_MB=4096


# Axiom Credentials
AXIOM_TOKEN=xaat-your-token
AXIOM_DATASET=your-dataset-name